# ── Local LLM stack (your existing services) ───────────────────────────────
# OpenAI-compatible vLLM auto-swap proxy
QHFI_LLM_BASE_URL=http://localhost:8001/v1
QHFI_LLM_API_KEY=not-needed
QHFI_LLM_MODEL=gemma            # default research model id served by the proxy
# Multi-step agent services (optional)
QHFI_LANGGRAPH_URL=http://localhost:8082
QHFI_CREWAI_URL=http://localhost:8083

# ── Market data / brokers (paper) ──────────────────────────────────────────
# Alpaca (US equities data + paper broker) — https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Crypto (ccxt) — read-only data needs no key; paper trading is simulated
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# Interactive Brokers (futures/equities, optional — requires extras: pip install -e ".[ib]")
IB_HOST=127.0.0.1
IB_PORT=7497          # 7497 = paper TWS, 4002 = paper gateway
IB_CLIENT_ID=1

# ── Paths ──────────────────────────────────────────────────────────────────
QHFI_DATA_DIR=./data
QHFI_REPORTS_DIR=./reports
QHFI_REGISTRY_DB=./registry.sqlite
